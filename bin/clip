#!/bin/bash

# Check if a path is provided
if [ -z "$1" ]; then
  echo "Usage: clip <path_to_file>"
  exit 1
fi

# Check if the file exists
if [ ! -f "$1" ]; then
  echo "File not found!"
  exit 1
fi

# Copy the file contents to the clipboard
cat "$1" | pbcopy

echo "File contents copied to clipboard."
