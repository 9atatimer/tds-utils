#!/usr/bin/env bash
# clone-scan — static safety scan of a freshly-cloned repo
#
# Purpose:
#   Inspect a repository working tree for "coding-agent poisoning" and
#   related auto-run hazards BEFORE you open it with an AI coding agent or
#   build it.  Designed to be invoked automatically from a global
#   post-checkout hook (see git-hooks/post-checkout) on clone, or run by
#   hand against any directory.
#
# Threat model (headline first):
#   - AGENT-FILE      Agent instruction files (CLAUDE.md, .cursorrules, MCP
#                     configs, ...) — the primary poisoning surface. Listed
#                     for review (informational).
#   - HIDDEN-UNICODE  Invisible / bidi-override / Unicode-tag characters used
#                     to smuggle instructions past a human reviewer.
#   - INJECTION       Prompt-injection phrasing aimed at hijacking an agent.
#   - AGENT-EXEC      Configs that make an agent/editor run a command on open
#                     (.claude hooks, MCP launch commands).
#   - AUTORUN         Code that runs the moment you install/open the repo
#                     (npm lifecycle scripts, .envrc, devcontainer/VS Code
#                     auto-run, curl|sh one-liners).
#
# SAFETY: this script only ever READS files. It never executes, sources, or
#   evaluates anything from the scanned repository.
#
# Usage:   clone-scan [-q] [-v] [PATH]      (PATH defaults to '.')
# Exit:    0 = no warnings, 2 = warnings found, 1 = usage error.
# Prereqs: bash, perl, grep, find.

set -euo pipefail

# --- Globals ---

ROOT=""
QUIET=false
VERBOSE=false
WARN_COUNT=0

# Directories never worth scanning (vendored / VCS / build output).
PRUNE_DIRS=(.git node_modules .venv venv vendor dist build .next .svn .hg .tox)

# --- Output helpers ---

emit_info() {
    local tag="$1" file="$2"
    ${QUIET} && return 0
    printf '  [INFO] %-13s %s\n' "${tag}" "${file#"${ROOT}"/}"
}

emit_warn() {
    local tag="$1" file="$2" detail="${3:-}"
    printf '  [WARN] %-13s %s%s\n' "${tag}" "${file#"${ROOT}"/}" \
        "${detail:+ — ${detail}}"
    WARN_COUNT=$((WARN_COUNT + 1))
}

# Build the shared --exclude-dir argument list for grep.
grep_excludes() {
    local d
    for d in "${PRUNE_DIRS[@]}"; do printf -- '--exclude-dir=%s\n' "${d}"; done
}

# --- Action functions (one detector each) ---

# Enumerate known agent-instruction files. Informational: presence is the
# attack surface, not proof of compromise.
list_agent_files() {
    find "${ROOT}" -type f \( \
        -name 'CLAUDE.md'   -o -name 'AGENT.md'  -o -name 'AGENTS.md'    \
        -o -name 'GEMINI.md' -o -name '.cursorrules' -o -name '.windsurfrules' \
        -o -name '.clinerules' -o -name '.aider.conf.yml' -o -name '.roomodes' \
        -o -name 'copilot-instructions.md' -o -name '*.mdc' \) \
        -not -path '*/.git/*' 2>/dev/null || true
}

# Build the list of regular files to hand to the perl unicode scanner.
list_scannable_files() {
    local prune=() d
    for d in "${PRUNE_DIRS[@]}"; do
        prune+=(-name "${d}" -o)
    done
    # Drop the trailing -o.
    unset 'prune[${#prune[@]}-1]'
    find "${ROOT}" \( -type d \( "${prune[@]}" \) -prune \) -o \
        -type f -print 2>/dev/null || true
}

# Scan text files for invisible / bidi / Unicode-tag characters.
# Emits "file:line:U+XXXX" lines for each occurrence.
scan_hidden_unicode() {
    local files
    readarray -t files < <(list_scannable_files)
    [[ ${#files[@]} -eq 0 ]] && return 0
    perl -CSD -e '
        for my $f (@ARGV) {
            next if -B $f;                       # skip binary files
            open my $fh, "<:encoding(UTF-8)", $f or next;
            my $ln = 0;
            while (my $line = <$fh>) {
                $ln++;
                $line =~ s/^\x{feff}// if $ln == 1;   # tolerate a leading BOM
                while ($line =~ /([\x{200b}-\x{200f}\x{2028}-\x{202e}\x{2060}-\x{2064}\x{2066}-\x{206f}\x{feff}\x{e0000}-\x{e007f}])/g) {
                    printf "%s:%d:U+%04X\n", $f, $ln, ord($1);
                }
            }
            close $fh;
        }
    ' "${files[@]}" 2>/dev/null || true
}

# Generic recursive content grep that tolerates "no match" (exit 1) under -e.
grep_repo() {
    local pattern="$1"
    local excludes
    readarray -t excludes < <(grep_excludes)
    grep -rIniE "${excludes[@]}" -e "${pattern}" "${ROOT}" 2>/dev/null || true
}

# --- Flow functions (logic / control flow) ---

report_agent_files() {
    local f
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        emit_info "AGENT-FILE" "${f}"
    done < <(list_agent_files)
}

report_hidden_unicode() {
    local line file ln cp
    while IFS= read -r line; do
        [[ -n "${line}" ]] || continue
        file="${line%%:*}"; line="${line#*:}"
        ln="${line%%:*}";   cp="${line#*:}"
        emit_warn "HIDDEN-UNICODE" "${file}" "line ${ln}: ${cp}"
    done < <(scan_hidden_unicode)
}

report_injection() {
    local pattern line file
    pattern='ignore (all |the )?(previous|prior|above) instructions'
    pattern+='|disregard (all |the )?(previous|prior|above)'
    pattern+='|do not (tell|inform|reveal to|mention to) the (user|human|developer)'
    pattern+='|you are now (a |an |in |operating|being)'
    pattern+='|new (instructions|directive)s?:'
    pattern+='|(send|exfiltrat|upload|post|leak) .{0,40}(secret|token|credential|password|env var|\.ssh|api[_ -]?key)'
    while IFS= read -r line; do
        [[ -n "${line}" ]] || continue
        file="${line%%:*}"
        emit_warn "INJECTION" "${file}" "matched hijack phrasing"
    done < <(grep_repo "${pattern}")
}

report_agent_exec() {
    local f
    # .claude / .cursor / .vscode settings declaring hooks.
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        if grep -qE '"hooks"[[:space:]]*:' "${f}" 2>/dev/null; then
            emit_warn "AGENT-EXEC" "${f}" "declares agent hooks (runs on session)"
        fi
    done < <(find "${ROOT}" -type f -path '*/.claude/*' \( -name 'settings.json' \
        -o -name 'settings.local.json' \) -not -path '*/.git/*' 2>/dev/null || true)

    # A .claude/hooks directory is itself an execution surface.
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        emit_warn "AGENT-EXEC" "${f}" "agent hook script"
    done < <(find "${ROOT}" -type f -path '*/.claude/hooks/*' \
        -not -path '*/.git/*' 2>/dev/null || true)

    # MCP server definitions that launch a command.
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        if grep -qE '"command"[[:space:]]*:' "${f}" 2>/dev/null; then
            emit_warn "AGENT-EXEC" "${f}" "MCP server launches a command"
        fi
    done < <(find "${ROOT}" -type f \( -name '.mcp.json' -o -name 'mcp.json' \) \
        -not -path '*/.git/*' 2>/dev/null || true)
}

report_autorun() {
    local f
    # npm lifecycle scripts that run automatically on install/pack.
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        if grep -qE '"(preinstall|install|postinstall|prepare|prepublish|prepublishOnly|prepack|postpack|preuninstall|postuninstall)"[[:space:]]*:' "${f}" 2>/dev/null; then
            emit_warn "AUTORUN" "${f}" "npm lifecycle script"
        fi
    done < <(find "${ROOT}" -type f -name 'package.json' \
        -not -path '*/.git/*' -not -path '*/node_modules/*' 2>/dev/null || true)

    # direnv: .envrc runs on cd into the directory.
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        emit_warn "AUTORUN" "${f}" "direnv runs this on cd"
    done < <(find "${ROOT}" -type f -name '.envrc' -not -path '*/.git/*' 2>/dev/null || true)

    # Dev container lifecycle commands.
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        if grep -qE '"(initializeCommand|onCreateCommand|updateContentCommand|postCreateCommand|postStartCommand|postAttachCommand)"' "${f}" 2>/dev/null; then
            emit_warn "AUTORUN" "${f}" "devcontainer lifecycle command"
        fi
    done < <(find "${ROOT}" -type f -name 'devcontainer.json' \
        -not -path '*/.git/*' 2>/dev/null || true)

    # VS Code tasks set to run on folder open.
    while IFS= read -r f; do
        [[ -n "${f}" ]] || continue
        if grep -qE 'folderOpen' "${f}" 2>/dev/null; then
            emit_warn "AUTORUN" "${f}" "VS Code task runs on folder open"
        fi
    done < <(find "${ROOT}" -type f -path '*/.vscode/*' -name 'tasks.json' \
        -not -path '*/.git/*' 2>/dev/null || true)

    # curl|sh / wget|bash one-liners anywhere in the tree.
    local line
    while IFS= read -r line; do
        [[ -n "${line}" ]] || continue
        f="${line%%:*}"
        emit_warn "AUTORUN" "${f}" "pipes a download straight into a shell"
    done < <(grep_repo '(curl|wget|fetch)[^|]*\|[[:space:]]*(sudo[[:space:]]+)?(ba)?sh\b')
}

run_scan() {
    ${QUIET} || printf 'clone-scan: scanning %s\n' "${ROOT}"

    report_agent_files
    report_hidden_unicode
    report_injection
    report_agent_exec
    report_autorun

    if (( WARN_COUNT > 0 )); then
        printf 'clone-scan: ⚠  %d warning(s) in %s — REVIEW before using this repo with a coding agent.\n' \
            "${WARN_COUNT}" "${ROOT}"
        return 2
    fi
    ${QUIET} || printf 'clone-scan: ✓ no issues found (%s)\n' "${ROOT}"
    return 0
}

usage() {
    cat <<'EOF'
Usage: clone-scan [-q] [-v] [PATH]

Statically scans PATH (default '.') for coding-agent poisoning and auto-run
hazards. Reads files only; never executes repo content.

  -q   quiet: print only when warnings are found
  -v   verbose
  -h   this help

Exit: 0 clean, 2 warnings found, 1 usage error.
EOF
}

# --- Main ---

main() {
    local opt
    while getopts "qvh" opt; do
        case "${opt}" in
            q) QUIET=true ;;
            v) VERBOSE=true ;;
            h) usage; exit 0 ;;
            *) usage; exit 1 ;;
        esac
    done
    shift $((OPTIND - 1))

    local target="${1:-.}"
    if [[ ! -d "${target}" ]]; then
        printf 'clone-scan: not a directory: %s\n' "${target}" >&2
        exit 1
    fi
    ROOT="$(cd "${target}" && pwd)"

    for tool in perl grep find; do
        command -v "${tool}" >/dev/null 2>&1 || {
            printf 'clone-scan: required tool not found: %s\n' "${tool}" >&2
            exit 1
        }
    done

    run_scan
}

main "$@"
