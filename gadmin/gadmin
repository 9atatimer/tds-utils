#!/usr/bin/env bash
# gadmin — universal project administration dispatcher (tds-utils edition).
#
# Usage: gadmin <command> [args]
#
# Commands resolve in this order:
#   1. Project extensions in <repo-root>/gadmin.d/<command>[.sh|.mjs]
#      (repo-root = walk up from $PWD looking for gadmin.d/, package.json,
#      or .git).
#   2. Legacy project extensions in <repo-root>/scripts/admin/<command>[...]
#      (back-compat with the pre-tds-utils layout).
#   3. Built-in admin commands shipped with gadmin (this script's
#      admin/<command>[...]).
#
# A built-in lookup also tries the `github-<command>` form so that
# `gadmin pr-comments` is shorthand for the github tool's pr-comments
# subcommand if no extension shadows it.
#
# Options:
#   -h, --help    Show this help message

set -euo pipefail

# --- Path resolution -------------------------------------------------------

# Resolve through symlinks (bin/gadmin -> ../gadmin/gadmin).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

# Built-in admin commands ship next to this script.
BUILTIN_ADMIN_DIR="$SCRIPT_DIR/admin"

# --- Project root discovery -----------------------------------------------

# Walk up from $PWD looking for an extension marker. Mirrors the logic in
# admin/lib.sh but inlined so the dispatcher has no source-time deps.
find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/gadmin.d" ] || [ -f "$dir/package.json" ] || [ -e "$dir/.git" ]; then
            printf '%s\n' "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

PROJECT_ROOT="$(find_project_root 2>/dev/null || true)"
PROJECT_EXT_DIR=""
LEGACY_EXT_DIR=""
if [ -n "$PROJECT_ROOT" ]; then
    [ -d "$PROJECT_ROOT/gadmin.d" ]      && PROJECT_EXT_DIR="$PROJECT_ROOT/gadmin.d"
    [ -d "$PROJECT_ROOT/scripts/admin" ] && LEGACY_EXT_DIR="$PROJECT_ROOT/scripts/admin"
fi

# --- Help -----------------------------------------------------------------

list_dir_executables() {
    local dir="$1"
    local label="$2"
    [ -n "$dir" ] && [ -d "$dir" ] || return 0
    local printed_header=false
    local cmd
    for cmd in "$dir"/*; do
        [ -e "$cmd" ] || continue
        [ -x "$cmd" ] || continue
        if [ "$printed_header" = false ]; then
            echo "$label"
            printed_header=true
        fi
        echo "  $(basename "$cmd")"
    done
    [ "$printed_header" = true ] && echo ""
    return 0
}

show_help() {
    cat <<'EOF'
Usage: gadmin <command> [args]

Built-in commands:
  github <subcmd>    GitHub integration (pr-comments, pending-comments, reply, actions, crsilo)

EOF
    list_dir_executables "$PROJECT_EXT_DIR" "Project extensions (gadmin.d/):"
    list_dir_executables "$LEGACY_EXT_DIR"  "Project extensions (legacy scripts/admin/):"
    echo "Run 'gadmin <command> --help' for command-specific options."
}

# --- Command resolution ---------------------------------------------------

# Print the first executable file matching any of the candidate basenames in
# the given directory. Empty stdout = no match. Tries common extensions.
find_in_dir() {
    local dir="$1"
    local command="$2"
    [ -n "$dir" ] && [ -d "$dir" ] || return 0
    local candidate
    for candidate in \
        "$dir/$command" \
        "$dir/${command}.sh" \
        "$dir/${command}.mjs" \
        "$dir/github-$command" \
        "$dir/github-${command}.sh" \
        "$dir/github-${command}.mjs"; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 0
}

resolve_command() {
    local command="$1"
    local found
    found="$(find_in_dir "$PROJECT_EXT_DIR" "$command")"
    [ -n "$found" ] && { printf '%s\n' "$found"; return 0; }
    found="$(find_in_dir "$LEGACY_EXT_DIR" "$command")"
    [ -n "$found" ] && { printf '%s\n' "$found"; return 0; }
    found="$(find_in_dir "$BUILTIN_ADMIN_DIR" "$command")"
    [ -n "$found" ] && { printf '%s\n' "$found"; return 0; }
    return 1
}

# --- Main -----------------------------------------------------------------

main() {
    if [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
        show_help
        exit 0
    fi

    local command="$1"
    shift

    local target
    if target="$(resolve_command "$command")" && [ -n "$target" ]; then
        exec "$target" "$@"
    fi

    echo "Unknown command: $command" >&2
    show_help >&2
    exit 1
}

main "$@"
