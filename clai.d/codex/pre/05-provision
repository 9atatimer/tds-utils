#!/usr/bin/env bash
# 05-provision -- sync agent tooling (skills, MCP configs) before launch.
#
# Runs `clai provision --offline-ok` as a clai pre-hook (issue #84). Numbered
# 05 so it sorts ahead of the MCP-editing hooks (10-*, 20-*). Fail-open: a
# clai pre-hook that exits non-zero ABORTS the agent launch, so every
# failure path below carries its own guard and main() always exits 0 --
# under -e (kept for consistency with the sibling 10-*/20-* hooks) an
# UNGUARDED command would block the launch, so keep new commands guarded.

set -euo pipefail

# --- Flow functions ---

run_provision() {
    if ! command -v clai >/dev/null 2>&1; then
        echo "[clai.d/05-provision] clai not on PATH; skipping provisioning" >&2
        return 0
    fi
    clai provision --offline-ok || echo "[clai.d/05-provision] clai provision failed (non-fatal)" >&2
}

# --- Main ---

main() {
    run_provision
    exit 0
}

main "$@"
