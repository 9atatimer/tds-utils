#!/usr/bin/env bash
# post-checkout - advisory clone-time security audit + merged-branch warning.
#
# Git has no post-clone hook, but `git clone` runs post-checkout after its
# initial checkout. Installed via a global hook template (init.templateDir),
# this hook is copied into every cloned/init'd repo and fires once on clone.
# See docs/clone-audit.md for the full mechanism and threat model.
#
# On an ORDINARY branch checkout (not a fresh clone) it also advisorily warns
# when the just-checked-out branch already has a terminal (MERGED/CLOSED) PR,
# so you don't resurrect a retired branch. This is a heads-up only; the
# pre-commit branch guard is what actually blocks. See docs/branch-guard.md.
#
# Args (from git): $1 = prev HEAD, $2 = new HEAD, $3 = 1 if branch checkout.
# It cannot affect the checkout outcome -- purely advisory.
#
# Portability: bash 3.2 / BSD-safe (this runs on whatever bash a clone is
# launched under, including macOS system bash 3.2 from an IDE/GUI). Output is
# ASCII-only to stay legible in non-UTF-8 locales / limited terminals.
#
# NOTE: `set -e` is intentionally omitted. This hook must NEVER disrupt a
# clone/checkout; it always exits 0.

set -uo pipefail

# --- Action functions ---

# True only for a fresh clone: a branch checkout (flag=1) whose previous HEAD is
# the null OID -- all zeros, non-empty (handles 40-zero SHA-1 and 64-zero
# SHA-256). A real `git checkout -b` has a non-zero prev HEAD, so it's skipped.
is_fresh_clone() {
    local prev_head="$1" branch_flag="$2"
    [ "${branch_flag}" = "1" ] || return 1
    case "${prev_head}" in
        '' | *[!0]* ) return 1 ;;
    esac
    return 0
}

# Opt-out via env var or git config.
audit_disabled() {
    [ "${TDS_CLONE_AUDIT:-1}" = "0" ] && return 0
    [ "$(git config --bool audit.enabled 2>/dev/null)" = "false" ] && return 0
    return 1
}

# `git worktree add` also fires with a null prev HEAD, but it targets your own
# trusted repo. A linked worktree's git-dir differs from its common git-dir; a
# fresh clone's are identical.
is_secondary_worktree() {
    local gitdir commondir
    gitdir="$(git rev-parse --git-dir 2>/dev/null || true)"
    commondir="$(git rev-parse --git-common-dir 2>/dev/null || true)"
    [ -n "${gitdir}" ] && [ "${gitdir}" != "${commondir}" ]
}

# Resolve clone-audit robustly (the bin dir may not be on PATH for IDE/GUI/
# script-initiated clones): git config -> PATH -> home-anchored fallbacks.
# audit.scannerPath is read with --type=path so a '~/...' value expands (a raw
# --get would not). No repo-location paths: resolution depends only on the
# user's git config and home dir. Prints the path on success; non-zero if not
# found.
locate_scanner() {
    local scanner cand
    scanner="$(git config --type=path --get audit.scannerPath 2>/dev/null || true)"
    if [ -z "${scanner}" ] || [ ! -x "${scanner}" ]; then
        scanner="$(command -v clone-audit 2>/dev/null || true)"
    fi
    if [ -z "${scanner}" ] || [ ! -x "${scanner}" ]; then
        # ${HOME:-} so an unset HOME can't abort the hook under `set -u`.
        cand="${HOME:-}/.local/bin/clone-audit"
        [ -n "${HOME:-}" ] && [ -x "${cand}" ] && scanner="${cand}"
    fi
    [ -n "${scanner}" ] && [ -x "${scanner}" ] || return 1
    printf '%s\n' "${scanner}"
}

# Branch-guard opt-out (shared with the pre-commit branch guard): env var or
# git config. Default is ENABLED (unset => on).
branch_guard_disabled() {
    [ "${TDS_BRANCH_GUARD:-1}" = "0" ] && return 0
    [ "$(git config --bool branchguard.enabled 2>/dev/null)" = "false" ] && return 0
    return 1
}

# Trunk branches never carry a "retired" PR verdict worth warning about.
is_trunk_branch() {
    case "$1" in
        master | main | develop | trunk ) return 0 ;;
    esac
    return 1
}

# Resolve branch-merged-check the same way locate_scanner resolves clone-audit:
# git config (--type=path so a '~/...' value expands) -> PATH -> home fallback.
# Prints the path on success; non-zero if not found.
locate_checker() {
    local checker cand
    checker="$(git config --type=path --get branchguard.checkerPath 2>/dev/null || true)"
    if [ -z "${checker}" ] || [ ! -x "${checker}" ]; then
        checker="$(command -v branch-merged-check 2>/dev/null || true)"
    fi
    if [ -z "${checker}" ] || [ ! -x "${checker}" ]; then
        cand="${HOME:-}/.local/bin/branch-merged-check"
        [ -n "${HOME:-}" ] && [ -x "${cand}" ] && checker="${cand}"
    fi
    [ -n "${checker}" ] && [ -x "${checker}" ] || return 1
    printf '%s\n' "${checker}"
}

# --- Flow functions ---

run_clone_audit() {
    local scanner root
    if ! scanner="$(locate_scanner)"; then
        echo "post-checkout: clone-audit not found (set git config audit.scannerPath); skipping audit." >&2
        return 0
    fi
    root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    printf '\npost-checkout: fresh clone detected - running clone-audit...\n'
    "${scanner}" "${root}" || true
}

# Advisory-only: warn (never block, always return 0) if the just-checked-out
# branch has a terminal PR. Cheap and silent when nothing is wrong.
warn_if_retired_branch() {
    local branch checker rc
    branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    [ -n "${branch}" ] || return 0
    is_trunk_branch "${branch}" && return 0
    checker="$(locate_checker)" || return 0
    "${checker}" -q "${branch}" >/dev/null 2>&1
    rc=$?
    [ "${rc}" = "0" ] || return 0
    printf '\n' >&2
    printf '=====================================================================\n' >&2
    printf 'WARNING: branch %s is RETIRED (it has a merged or closed PR).\n' "${branch}" >&2
    printf 'Do not commit here -- branch names must not be reused.\n' >&2
    printf 'Cut a fresh branch off your default branch for new work.\n' >&2
    printf '=====================================================================\n' >&2
    return 0
}

# --- Main (git passes prev-HEAD, new-HEAD, branch-flag positionally) ---

main() {
    # Fresh clone: run the security audit and stop (mutually exclusive with the
    # branch warning -- a fresh clone has a null prev HEAD).
    if is_fresh_clone "${1:-}" "${3:-}"; then
        audit_disabled        && exit 0
        is_secondary_worktree && exit 0
        run_clone_audit
        exit 0
    fi
    # Ordinary branch checkout: advisory merged-branch warning only.
    [ "${3:-}" = "1" ]        || exit 0
    branch_guard_disabled     && exit 0
    is_secondary_worktree     && exit 0
    warn_if_retired_branch
    exit 0
}

main "$@"
