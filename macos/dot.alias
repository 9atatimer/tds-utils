# Grep shorthand
alias rgrep='grep -r --exclude-dir=.git'

# bazelisk before bazel
alias bazil=bazelisk

# tf before terraform
alias tf=terraform

## ec before emacsclient
#alias ec='emacsclient -n'

# ec before emacsclient with wildcard support

# npx prettier before pretty
alias pretty='npx prettier --write'

## screen-aware aliases
# Wrap ssh so screen window title shows remote host
ssh() {
  printf '\ek%s\e\\' "${1%%.*}"   # set screen title
  command ssh "$@"
}

# Tailscale doesn't get added to the path for some reason
alias tailscale="/Applications/Tailscale.app/Contents/MacOS/Tailscale"

alias bit-tunnel="ssh -L 5678:127.0.0.1:5678 stumpf@100.125.95.68"

# goldfish — recent-work report across repos
alias gf=goldfish

# Route AI coding agents through clai (overlay hooks + OpenTelemetry env).
# Interactive shells only — scripts that call these binaries directly are
# unaffected. clai launches the real agent via subprocess, which does not
# inherit these aliases, so there is no recursion. For a raw run, bypass
# with `command <agent>` or `\<agent>`.
alias claude='clai claude'
# Remote-control Claude from your phone over Telegram (still via clai for telemetry).
alias jog-claude='clai claude --channels plugin:telegram@claude-plugins-official'
# The Muscles from Brussels: same, but skips permission prompts for unattended runs.
# Only point this at repos you trust — it kicks the gatekeeper in the face.
alias jog-claude-yolo='clai claude --channels plugin:telegram@claude-plugins-official --dangerously-skip-permissions'
# Antigravity CLI (agy) — Google retired the gemini CLI; agy replaced it.
alias agy='clai agy'
alias codex='clai codex'
alias opencode='clai opencode'
